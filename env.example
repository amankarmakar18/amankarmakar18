# ──────────────────────────────────────────────────────────────────────────────
# Zade Ads Bot V4 — Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Telegram API Credentials ───────────────────────────────────────
# Get from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Your main bot token from @BotFather
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional but STRONGLY recommended: a second bot for sending notifications
# This reduces load on your main bot's message quota
LOGGER_BOT_TOKEN=123456789:BBFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── REQUIRED: MongoDB ─────────────────────────────────────────────────────────
# Use MongoDB Atlas (recommended) or any replica-set enabled MongoDB.
# Atlas free tier works fine: https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=zade_ads_v4

# ── REQUIRED: Encryption Key ──────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NEVER change this after launch — it will invalidate all stored sessions.
ENCRYPTION_KEY=your-fernet-key-here=

# ── REQUIRED: Admin User IDs ──────────────────────────────────────────────────
# Comma-separated Telegram user IDs of admins
ADMIN_IDS=123456789,987654321

# ── Force-Join Configuration ──────────────────────────────────────────────────
# Username or @handle of the channel/group users must join
FORCE_JOIN_CHANNEL=@your_channel
FORCE_JOIN_GROUP=@your_group
# URL or file_id of the image shown in the force-join prompt
FORCE_JOIN_IMAGE=

# ── Channel IDs for Logging ───────────────────────────────────────────────────
# The bot must be an admin in these channels.
# You can use the same channel ID for all three if desired.
PAYMENT_LOG_CHANNEL_ID=-100xxxxxxxxxx
TECH_LOG_CHANNEL_ID=-100xxxxxxxxxx
SETUP_GROUP_ID=-100xxxxxxxxxx

# ── Payment / Wallet Configuration ───────────────────────────────────────────
ENABLE_PAID_SERVICE=true

# Your Bitcoin receive address
BTC_WALLET=bc1qxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your USDT TRC-20 (Tron) receive address
USDT_TRC20_WALLET=Txxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Tron (TRX) receive address
TRX_WALLET=Txxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Broadcast Engine Settings ─────────────────────────────────────────────────
MIN_DELAY=120
MAX_DELAY=86400
DEFAULT_DELAY=300
MAX_CONCURRENT_BROADCASTS=50
PROGRESS_UPDATE_MIN_INTERVAL=30

# Circuit Breaker — groups suspended after N consecutive failures
GROUP_FAILURE_SUSPEND_THRESHOLD=3
GROUP_SUSPEND_HOURS=6
# Groups permanently dead after N total failures
DEAD_GROUP_THRESHOLD=10

# ── Login Settings ────────────────────────────────────────────────────────────
LOGIN_TIMEOUT_SECONDS=600
MAX_LOGIN_ATTEMPTS_PER_HOUR=3
MAX_OTP_ATTEMPTS=3

# ── Rate Limits ───────────────────────────────────────────────────────────────
ACTION_COOLDOWN_SECONDS=1.5
PAYMENT_COOLDOWN_SECONDS=30.0
JOIN_CHECK_COOLDOWN_SECONDS=10.0
# Max messages per second for admin broadcast to all users
ADMIN_BROADCAST_RATE=25

# ── Health Check ──────────────────────────────────────────────────────────────
HEALTH_CHECK_PORT=8080

# ── Bot Identity ──────────────────────────────────────────────────────────────
BOT_NAME=Zade Ads Bot
MAINTENANCE_MODE=false

# ── Referral ──────────────────────────────────────────────────────────────────
REFERRAL_BONUS_DAYS=3

# ── Database Pool ─────────────────────────────────────────────────────────────
DB_MAX_POOL_SIZE=20
DB_MIN_POOL_SIZE=5
